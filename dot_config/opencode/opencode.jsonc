{
  "$schema": "https://opencode.ai/config.json",

  // Permissions — moderate: allow reads, ask before writes/bash
  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow"
  },

  // Enable LSP for diagnostics & go-to-definition
  "lsp": true,

  // Enable code formatters
  "formatter": true,

  // Context compaction
  "compaction": {
    "auto": true,
    "prune": true
  },

  // MCP servers (add your servers here)
  "mcp": {},

  // Custom instructions (add paths to project guidelines, etc.)
  "instructions": [],

  // File watcher — ignore noisy dirs
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "build/**"]
  }
}
